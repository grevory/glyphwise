{
  "name": "glyphcheck",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/app",
    "build": "npm run build -w packages/score && npm run build -w packages/app",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "preview": "npm run preview -w packages/app"
  }
}
